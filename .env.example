VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# True = simpan gambar produk ke server lokal folder public/uploads untuk testing lokal.
# False = upload gambar ke Cloudflare R2 lewat endpoint/worker.
VITE_LOCAL_STORAGE=True
VITE_LOCAL_API_ENDPOINT=http://127.0.0.1:8081/api
VITE_LOCAL_UPLOAD_ENDPOINT=http://127.0.0.1:8081/upload
VITE_LOCAL_DELETE_ENDPOINT=http://127.0.0.1:8081/delete
VITE_R2_UPLOAD_ENDPOINT=https://your-worker.your-subdomain.workers.dev/upload
VITE_R2_DELETE_ENDPOINT=https://your-worker.your-subdomain.workers.dev/delete
VITE_R2_PUBLIC_URL=https://pub-your-r2-domain.example.com
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
